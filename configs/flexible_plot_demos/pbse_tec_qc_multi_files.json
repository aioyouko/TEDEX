{
  "name": "Demo cooling capacity from multiple CSV files",
  "plot": {
    "kind": "line",
    "x": {"column": "I", "label": "$I$ (A)"},
    "series": [
      {
        "source": "data/demo/max_cooling_capacity/1.csv",
        "y": {"column": "Q", "label": "$Q_{\\mathrm{c}}$ (W)"},
        "property": "qc",
        "group_value": "Condition 1",
        "marker": "o",
        "line_width": 1.4
      },
      {
        "source": "data/demo/max_cooling_capacity/2.csv",
        "y": {"column": "Q", "label": "$Q_{\\mathrm{c}}$ (W)"},
        "property": "qc",
        "group_value": "Condition 2",
        "marker": "s",
        "line_width": 1.4
      },
      {
        "source": "data/demo/max_cooling_capacity/3.csv",
        "y": {"column": "Q", "label": "$Q_{\\mathrm{c}}$ (W)"},
        "property": "qc",
        "group_value": "Condition 3",
        "marker": "^",
        "line_width": 1.4
      }
    ],
    "xlabel": "$I$ (A)",
    "ylabel": "$Q_{\\mathrm{c}}$ (W)",
    "legend_loc": "best",
    "x_margin": 0.04,
    "y_margin": 0.08
  },
  "output": {
    "dir": "outputs/figures/flexible_demos",
    "stem": "demo_current_vs_cooling_capacity",
    "formats": ["png", "pdf"],
    "normalized_csv": true,
    "copy_to_data_dir": true
  }
}

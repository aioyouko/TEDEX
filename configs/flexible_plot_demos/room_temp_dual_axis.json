{
  "name": "Demo composition Hall dual-line plot",
  "data": [{"path": "data/demo/composition_Hall/nu_muh.csv"}],
  "plot": {
    "kind": "dual_line",
    "x": {"column": "x", "label": "Content"},
    "series": [
      {
        "y": {"column": "concentration", "label": "$n_{\\mathrm{H}}$ ($10^{19}$ cm$^{-3}$)"},
        "property": "carrier_concentration",
        "group_value": "$n_{\\mathrm{H}}$",
        "legend_label": "$n_{\\mathrm{H}}$",
        "color": "#d62728",
        "marker": "o",
        "line_width": 1.4
      },
      {
        "y": {"column": "mobility", "label": "$\\mu_{\\mathrm{H}}$ (cm$^2$ V$^{-1}$ s$^{-1}$)"},
        "property": "mobility",
        "group_value": "$\\mu_{\\mathrm{H}}$",
        "legend_label": "$\\mu_{\\mathrm{H}}$",
        "color": "#1f77b4",
        "marker": "s",
        "line_width": 1.4
      }
    ],
    "xlabel": "Content",
    "ylabel": "$n_{\\mathrm{H}}$ ($10^{19}$ cm$^{-3}$)",
    "right_ylabel": "$\\mu_{\\mathrm{H}}$ (cm$^2$ V$^{-1}$ s$^{-1}$)",
    "yscale": "log",
    "y_tick_format": "plain",
    "legend_loc": "best",
    "x_margin": 0.04,
    "y_margin": 0.08
  },
  "output": {
    "dir": "outputs/figures/flexible_demos",
    "stem": "demo_composition_hall_dual_line",
    "formats": ["png", "pdf"],
    "normalized_csv": true,
    "copy_to_data_dir": true
  }
}

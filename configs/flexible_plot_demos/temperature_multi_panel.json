{
  "name": "Demo temperature multi-panel transport plot",
  "plot": {
    "kind": "multi_panel",
    "x": {"column": "x", "label": "$T$ (K)"},
    "series": [
      {
        "source": "data/demo/temperature_vs_mobility/1.csv",
        "y": {"column": "y", "label": "$\\mu_{\\mathrm{H}}$ (cm$^2$ V$^{-1}$ s$^{-1}$)"},
        "property": "mobility",
        "group_value": "Mobility"
      },
      {
        "source": "data/demo/temperature_vs_carrier_concentration/1.csv",
        "y": {"column": "y", "label": "$n_{\\mathrm{H}}$ ($10^{19}$ cm$^{-3}$)"},
        "property": "carrier_concentration",
        "group_value": "Carrier concentration"
      }
    ],
    "xlabel": "$T$ (K)",
    "x_major": 100,
    "x_minor": 50,
    "show_title": false
  },
  "output": {
    "dir": "outputs/figures/flexible_demos",
    "stem": "demo_temperature_multi_panel",
    "formats": ["png", "pdf"],
    "normalized_csv": true,
    "copy_to_data_dir": true
  }
}

{
  "name": "eta",
  "plot": {
    "kind": "line",
    "x": {
      "column": "I_A",
      "label": "$I$ (A)"
    },
    "series": [
      {
        "y": {
          "column": "eta_percent",
          "label": "$\\eta$ (%)"
        },
        "property": "eta",
        "group_value": "$\\eta$",
        "marker": "o",
        "line_width": 1.4
      }
    ],
    "xlabel": "$I$ (A)",
    "ylabel": "$\\eta$ (%)",
    "legend": "none",
    "x_margin": 0.04,
    "y_margin": 0.08
  },
  "output": {
    "dir": "outputs/figures/flexible",
    "stem": "eta",
    "formats": ["png", "pdf"],
    "normalized_csv": true,
    "copy_to_data_dir": true
  }
}

{
  "name": "te_temperature_vs_power_factor",
  "plot": {
    "kind": "line",
    "x": {
      "column": "Temperature",
      "label": "$T$ (K)"
    },
    "group": {
      "semantic": "sample"
    },
    "series": [
      {
        "y": {
          "column": "Power_Factor",
          "scale": 10000.0,
          "label": "$PF$ ($\\mu$W cm$^{-1}$ K$^{-2}$)"
        },
        "property": "power_factor",
        "marker": "o",
        "line_width": 1.4
      }
    ],
    "xlabel": "$T$ (K)",
    "x_major": 100,
    "x_minor": 50,
    "ylabel": "$PF$ ($\\mu$W cm$^{-1}$ K$^{-2}$)",
    "legend": "inside",
    "legend_loc": "best",
    "x_margin": 0.04,
    "y_margin": 0.08
  },
  "output": {
    "dir": "outputs/figures/te",
    "stem": "te_temperature_vs_power_factor",
    "formats": ["png", "pdf"],
    "normalized_csv": true,
    "copy_to_data_dir": true
  }
}

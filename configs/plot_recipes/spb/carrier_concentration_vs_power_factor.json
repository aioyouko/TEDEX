{
  "name": "spb_carrier_concentration_vs_power_factor",
  "plot": {
    "kind": "line",
    "x": {
      "column": "n_H_cm-3",
      "label": "$n_{\\mathrm{H}}$ (cm$^{-3}$)"
    },
    "series": [
      {
        "y": {
          "column": "PF_uW_cm-1_K-2",
          "label": "$PF$ ($\\mu$W cm$^{-1}$ K$^{-2}$)"
        },
        "property": "power_factor",
        "group_value": "$PF$",
        "marker": "o",
        "line_width": 1.4
      }
    ],
    "xlabel": "$n_{\\mathrm{H}}$ (cm$^{-3}$)",
    "ylabel": "$PF$ ($\\mu$W cm$^{-1}$ K$^{-2}$)",
    "xscale": "log",
    "legend": "none",
    "x_margin": 0.04,
    "y_margin": 0.08
  },
  "output": {
    "dir": "outputs/figures/flexible",
    "stem": "spb_carrier_concentration_vs_power_factor",
    "formats": ["png", "pdf"],
    "normalized_csv": true,
    "copy_to_data_dir": true
  }
}

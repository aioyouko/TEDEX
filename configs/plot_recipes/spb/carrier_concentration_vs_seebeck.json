{
  "name": "spb_carrier_concentration_vs_seebeck",
  "plot": {
    "kind": "line",
    "x": {
      "column": "n_H_cm-3",
      "label": "$n_{\\mathrm{H}}$ (cm$^{-3}$)"
    },
    "series": [
      {
        "y": {
          "column": "Seebeck_uV_K",
          "label": "$S$ (\u00b5V K$^{-1}$)"

    "xlabel": "$n_{\\mathrm{H}}$ (cm$^{-3}$)",
    "ylabel": "$S$ (\u00b5V K$^{-1}$)",
    "xscale": "log",
    "legend": "none",
    "x_margin": 0.04,
    "y_margin": 0.08
  },
  "output": {
    "dir": "outputs/figures/flexible",

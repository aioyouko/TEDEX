{
  "name": "temperature_vs_mobility",
  "plot": {
    "kind": "line",
    "x": {
      "column": "T_K",
      "label": "$T$ (K)"
    },
    "series": [
      {
        "y": {
          "column": "mu_H_cm2_V-1_s-1",
          "label": "$\\mu_{\\mathrm{H}}$ (cm$^2$ V$^{-1}$ s$^{-1}$)"
        },
        "property": "mobility",
        "group_value": "$\\mu_{\\mathrm{H}}$",
        "marker": "o",
        "line_width": 1.4
      }
    ],
    "xlabel": "$T$ (K)",
    "x_major": 100,
    "x_minor": 50,
    "ylabel": "$\\mu_{\\mathrm{H}}$ (cm$^2$ V$^{-1}$ s$^{-1}$)",
    "legend": "none",
    "x_margin": 0.04,
    "y_margin": 0.08
  },
  "output": {
    "dir": "outputs/figures/flexible",
    "stem": "temperature_vs_mobility",
    "formats": ["png", "pdf"],
    "normalized_csv": true,
    "copy_to_data_dir": true
  }
}

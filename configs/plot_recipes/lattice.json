{
  "name": "lattice",
  "plot": {
    "kind": "scatter",
    "x": {
      "column": "content",
      "label": "Content"
    },
    "series": [
      {
        "y": {
          "column": "Lattice_Parameter_A",
          "label": "Lattice Parameter ($\\AA$)"
        },
        "property": "lattice_parameter",
        "group_value": "Lattice parameter",
        "marker": "o",
        "marker_size": 5.5
      }
    ],
    "xlabel": "Content",
    "ylabel": "Lattice Parameter ($\\AA$)",
    "legend": "none",
    "x_margin": 0.06,
    "y_margin": 0.08
  },
  "output": {
    "dir": "outputs/figures/flexible",
    "stem": "lattice",
    "formats": ["png", "pdf"],
    "normalized_csv": true,
    "copy_to_data_dir": true
  }
}
